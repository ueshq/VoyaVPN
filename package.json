{
  "name": "voyavpn",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "dev": "node scripts/tauri.mjs dev",
    "dev:web": "vite --host 127.0.0.1 --port 1420",
    "build": "tsc -b --pretty false && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest",
    "lint": "eslint .",
    "smoke:frontend": "playwright test",
    "bindings": "node scripts/bindings.mjs",
    "bindings:check": "node scripts/bindings.mjs --check",
    "i18n:import": "node scripts/import-resx-locales.mjs",
    "i18n:check": "node scripts/import-resx-locales.mjs --check",
    "check:rust:fmt": "cargo fmt --all --check",
    "check:rust:clippy": "cargo clippy --workspace --all-targets -- -D warnings",
    "check:rust:test": "node scripts/check-rust-test.mjs",
    "check:frontend:typecheck": "pnpm typecheck",
    "check:frontend:test": "pnpm test --run",
    "check:frontend:lint": "pnpm lint",
    "check:bindings": "pnpm bindings:check",
    "verify:ci": "node scripts/verify-ci.mjs",
    "release:record": "node scripts/release-record.mjs",
    "release:artifacts": "node scripts/release-artifacts.mjs",
    "release:verify-staging": "node scripts/verify-release-staging.mjs",
    "release:updater": "node scripts/release-updater-metadata.mjs",
    "check:release:dry-run": "node scripts/check-release-readiness.mjs --mode dry-run",
    "check:release:stable": "node scripts/check-release-readiness.mjs --mode stable --tauri-config target/release-config/tauri.updater.stable.generated.json",
    "tauri": "node scripts/tauri.mjs",
    "tauri:dev": "pnpm dev",
    "tauri:build": "node scripts/tauri-build.mjs",
    "tauri:stable-updater-config": "node scripts/tauri-build.mjs --write-stable-updater-config"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.26",
    "@tauri-apps/api": "^2.11.0",
    "@uiw/react-codemirror": "^4.25.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.3.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
