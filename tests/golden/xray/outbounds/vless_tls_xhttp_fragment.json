{
  "tag": "proxy",
  "protocol": "vless",
  "settings": {
    "vnext": [
      {
        "address": "server.example",
        "port": 443,
        "users": [
          {
            "id": "00000000-0000-0000-0000-000000000001",
            "email": "t@t.tt",
            "encryption": "none"
          }
        ]
      }
    ]
  },
  "streamSettings": {
    "network": "xhttp",
    "security": "tls",
    "tlsSettings": {
      "allowInsecure": false,
      "serverName": "tls.example",
      "alpn": [
        "h2",
        "http/1.1"
      ],
      "fingerprint": "chrome",
      "echConfigList": "tls.example+https://ech.example/config",
      "echForceQuery": "full"
    },
    "xhttpSettings": {
      "path": "/xhttp",
      "host": "cdn.example",
      "mode": "stream-up",
      "extra": {
        "downloadSettings": {
          "address": "download.example"
        }
      }
    },
    "finalmask": {
      "tcp": [
        {
          "type": "fragment",
          "settings": {
            "packets": "tlshello",
            "length": "50-100",
            "delay": "10-20"
          }
        }
      ],
      "udp": [
        {
          "type": "noise",
          "settings": {
            "length": "10-20",
            "delay": "10-16"
          }
        }
      ]
    }
  },
  "mux": {
    "enabled": false,
    "concurrency": -1
  }
}
