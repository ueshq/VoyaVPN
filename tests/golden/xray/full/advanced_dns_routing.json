{
  "dns": {
    "enableParallelQuery": true,
    "hosts": {
      "example.test": [
        "1.2.3.4",
        "5.6.7.8"
      ]
    },
    "serveStale": true,
    "servers": [
      {
        "address": "https://cloudflare-dns.com/dns-query",
        "domains": [
          "domain:proxy.example",
          "full:special,domain"
        ],
        "skipFallback": true
      },
      {
        "address": "119.29.29.29",
        "domains": [
          "domain:direct.example",
          "full:ech.example"
        ],
        "skipFallback": true,
        "tag": "direct-dns-1"
      },
      {
        "address": "https://dns.alidns.com/dns-query",
        "domains": [
          "domain:direct.example",
          "full:ech.example"
        ],
        "skipFallback": true,
        "tag": "direct-dns-2"
      },
      {
        "address": "https://cloudflare-dns.com/dns-query",
        "domains": [
          "geosite:google"
        ],
        "skipFallback": true
      },
      {
        "address": "119.29.29.29",
        "domains": [
          "geosite:cn"
        ],
        "expectedIPs": [
          "geoip:cn",
          "1.1.1.1"
        ],
        "skipFallback": true,
        "tag": "direct-dns-3"
      },
      {
        "address": "https://dns.alidns.com/dns-query",
        "domains": [
          "geosite:cn"
        ],
        "expectedIPs": [
          "geoip:cn",
          "1.1.1.1"
        ],
        "skipFallback": true,
        "tag": "direct-dns-4"
      },
      {
        "address": "223.5.5.5",
        "domains": [
          "full:dns.alidns.com",
          "full:cloudflare-dns.com"
        ],
        "skipFallback": true
      },
      {
        "address": "119.29.29.29",
        "skipFallback": false,
        "tag": "direct-dns-5"
      },
      {
        "address": "https://dns.alidns.com/dns-query",
        "skipFallback": false,
        "tag": "direct-dns-6"
      }
    ],
    "tag": "dns-module"
  },
  "fakedns": [
    {
      "ipPool": "198.18.0.0/15",
      "poolSize": 65535
    }
  ],
  "outbounds": [
    {
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "main.example",
            "port": 443,
            "users": [
              {
                "email": "t@t.tt",
                "encryption": "none",
                "id": "00000000-0000-0000-0000-000000000005"
              }
            ]
          }
        ]
      },
      "tag": "proxy",
      "targetStrategy": "UseIPv4"
    },
    {
      "protocol": "freedom",
      "settings": {
        "domainStrategy": "UseIP",
        "userLevel": 0
      },
      "tag": "direct",
      "targetStrategy": null
    },
    {
      "protocol": "blackhole",
      "settings": null,
      "tag": "block",
      "targetStrategy": null
    },
    {
      "protocol": "socks",
      "settings": {
        "servers": [
          {
            "address": "127.0.0.1",
            "port": 1080,
            "users": [
              {
                "level": 1,
                "pass": "pass",
                "user": "user"
              }
            ]
          }
        ]
      },
      "tag": "detour-id-proxy-detour-node",
      "targetStrategy": "UseIPv4"
    }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "inboundTag": [
          "api"
        ],
        "outboundTag": "api",
        "type": "field"
      },
      {
        "domain": [
          "geosite:google",
          "domain:proxy.example"
        ],
        "outboundTag": "proxy",
        "type": "field"
      },
      {
        "domain": [
          "full:special,domain"
        ],
        "outboundTag": "detour-id-proxy-detour-node",
        "type": "field"
      },
      {
        "ip": [
          "0.0.0.0/0"
        ],
        "network": "tcp,udp",
        "outboundTag": "direct",
        "port": "0-65535",
        "type": "field"
      },
      {
        "inboundTag": [
          "direct-dns-1",
          "direct-dns-2",
          "direct-dns-3",
          "direct-dns-4",
          "direct-dns-5",
          "direct-dns-6"
        ],
        "outboundTag": "direct",
        "type": "field"
      },
      {
        "inboundTag": [
          "dns-module"
        ],
        "outboundTag": "proxy",
        "type": "field"
      }
    ]
  }
}
