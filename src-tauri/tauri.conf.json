{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoyaVPN",
  "version": "0.1.0",
  "identifier": "app.voyavpn.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev:web",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VoyaVPN",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' data:; font-src 'self'; object-src 'none'; frame-src 'none'; base-uri 'none'; form-action 'none'"
    }
  },
  "bundle": {
    "active": true,
    "publisher": "VoyaVPN",
    "homepage": "https://github.com/voyavpn/voyavpn",
    "category": "DeveloperTool",
    "shortDescription": "Cross-platform proxy client",
    "longDescription": "VoyaVPN is a cross-platform desktop proxy client with a bundled sing-box core seed and app update flow.",
    "license": "MIT",
    "copyright": "Copyright (c) VoyaVPN contributors",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": ["app", "dmg", "nsis", "msi", "deb", "rpm", "appimage"],
    "createUpdaterArtifacts": false,
    "resources": {
      "../docs/release/THIRD_PARTY_NOTICES.md": "release/THIRD_PARTY_NOTICES.md"
    },
    "externalBin": [],
    "macOS": {
      "bundleName": "VoyaVPN",
      "minimumSystemVersion": "10.15",
      "hardenedRuntime": true,
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        }
      }
    },
    "windows": {
      "allowDowngrades": false,
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English"],
        "displayLanguageSelector": false
      },
      "wix": {
        "upgradeCode": "81f9b48c-cd6b-566b-9904-9f89ac741525",
        "language": "en-US"
      }
    },
    "linux": {
      "deb": {
        "section": "net",
        "priority": "optional"
      },
      "rpm": {
        "release": "1"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": []
    }
  }
}
